# These run on Linux (the VM). Force LF so a Windows checkout never injects
# CRLF (which breaks `#!/usr/bin/env bash` and the GNU assembler).
*.sh    text eol=lf
*.s     text eol=lf
*.py    text eol=lf
*.service text eol=lf
*.rs    text eol=lf
*.yml   text eol=lf
PKGBUILD    text eol=lf
*.install   text eol=lf
